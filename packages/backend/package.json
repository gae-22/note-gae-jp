{
    "name": "@note-gae-jp/backend",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsup && tsc --noCheck --emitDeclarationOnly",
        "typecheck": "tsc --noEmit --noCheck",
        "start": "node dist/index.js --port 8006",
        "db:generate": "drizzle-kit generate:sqlite",
        "db:migrate": "tsx src/db/migrate.ts && tsx src/db/ensure-fts.ts",
        "db:seed": "tsx src/db/seed.ts"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.9",
        "@hono/zod-validator": "^0.7.6",
        "@node-rs/argon2": "^2.0.2",
        "@note-gae-jp/shared": "workspace:*",
        "better-sqlite3": "^9.4.0",
        "dotenv": "^16.4.1",
        "drizzle-orm": "^0.29.3",
        "hono": "^4.0.0",
        "hono-rate-limiter": "^0.5.3",
        "ulid": "^3.0.2",
        "uuid": "^13.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.19.33",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/uuid": "^11.0.0",
        "drizzle-kit": "^0.20.13",
        "tsup": "^8.5.1",
        "tsx": "^4.7.0",
        "typescript": "^5.9.3"
    }
}
