# Environment
NODE_ENV=development
PORT=3000

# Security — MUST be at least 32 characters in production
SESSION_SECRET=dev-secret-key-minimum-32-characters-long!!

# Database
DATABASE_PATH=./data/note-gae.db

# Uploads
UPLOADS_DIR=../../uploads

# Note lock TTL (seconds)
LOCK_TTL_SECONDS=300

# Orphan file cleanup (days)
ORPHAN_TTL_DAYS=7
