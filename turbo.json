{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "lint": {},
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["build"],
            "persistent": true,
            "passThroughEnv": ["NODE_ENV"]
        },
        "db:migrate": {
            "cache": false
        }
    }
}
